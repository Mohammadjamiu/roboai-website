---
import { ArrowRight } from "lucide-react";
---

<section class="relative py-20 md:py-28 overflow-hidden">
  <div class="absolute inset-0 bg-primary/5"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-primary/10 rounded-full blur-[100px]"></div>

  <div class="relative z-10 responsive-container">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight mb-4 reveal">
        Start building your future today
      </h2>
      <p class="text-base text-muted-foreground mb-8 reveal reveal-delay-1">
        Join the next cohort of students learning to build intelligent systems.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 reveal reveal-delay-2">
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 h-12 px-8 text-sm font-medium rounded-full bg-primary text-primary-foreground hover:bg-primary/90 transition-all duration-200 shadow-sm hover:shadow-md hover:shadow-primary/10"
        >
          Get Started
          <ArrowRight className="w-4 h-4" />
        </a>
        <a
          href="/courses"
          class="inline-flex items-center justify-center gap-2 h-12 px-8 text-sm font-medium rounded-full text-foreground bg-background hover:bg-muted transition-all duration-200"
        >
          Browse Courses
        </a>
      </div>
    </div>
  </div>
</section>
