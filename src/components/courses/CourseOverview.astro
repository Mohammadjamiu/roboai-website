---
interface Phase {
  phase: string;
  weeks: string;
  focus: string;
  outcome: string;
}

interface Props {
  intro: string;
  description: string;
  phases: Phase[];
}

const { intro, description, phases } = Astro.props;
---

<section class="py-16 md:py-24">
  <div class="responsive-container">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12 reveal">
        <h2 class="text-2xl md:text-3xl font-semibold tracking-tight mb-4">Program Overview</h2>
        <p class="text-muted-foreground leading-relaxed">{intro}</p>
      </div>
      <p class="text-muted-foreground leading-relaxed mb-8 reveal">{description}</p>
      <div class="overflow-x-auto reveal">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border">
              <th class="text-left py-3 px-4 font-semibold">Phase</th>
              <th class="text-left py-3 px-4 font-semibold">Weeks</th>
              <th class="text-left py-3 px-4 font-semibold">Focus Area</th>
              <th class="text-left py-3 px-4 font-semibold">Outcome</th>
            </tr>
          </thead>
          <tbody>
            {phases.map((p) => (
              <tr class="border-b border-border/50">
                <td class="py-3 px-4 font-medium text-primary">{p.phase}</td>
                <td class="py-3 px-4 text-muted-foreground font-mono text-xs">{p.weeks}</td>
                <td class="py-3 px-4">{p.focus}</td>
                <td class="py-3 px-4 text-muted-foreground text-xs">{p.outcome}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
