---
import { GraduationCap, ArrowRight } from "lucide-react";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<section class="py-16 md:py-24 bg-muted/30">
  <div class="responsive-container">
    <div class="max-w-3xl mx-auto text-center">
      <div class="p-8 md:p-12 rounded-2xl bg-primary/5 border border-primary/15 reveal">
        <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary mx-auto mb-5">
          <GraduationCap className="w-7 h-7" />
        </div>
        <h2 class="text-2xl md:text-3xl font-semibold mb-3">{title}</h2>
        <p class="text-muted-foreground mb-8 max-w-lg mx-auto">{description}</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 h-12 px-8 rounded-full text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 transition-all duration-200 shadow-sm hover:shadow-md hover:shadow-primary/10"
          >
            Enroll Now
            <ArrowRight className="w-4 h-4" />
          </a>
          <a
            href="/courses"
            class="inline-flex items-center justify-center gap-2 h-12 px-8 rounded-full text-sm font-medium border border-input bg-background hover:bg-muted transition-all duration-200"
          >
            View All Courses
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
