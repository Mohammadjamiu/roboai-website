---
import { Target } from "lucide-react";

interface Outcome {
  area: string;
  skill: string;
}

interface Props {
  outcomes: Outcome[];
}

const { outcomes } = Astro.props;
---

<section class="py-16 md:py-24">
  <div class="responsive-container">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12 reveal">
        <h2 class="text-2xl md:text-3xl font-semibold tracking-tight mb-4">Learning Outcomes</h2>
        <p class="text-muted-foreground">Skills you'll have by the end of the program.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {outcomes.map((o, i) => (
          <div class:list={["flex gap-3 p-4 rounded-xl border border-border bg-card shadow-sm reveal", `reveal-delay-${(i % 2) + 1}`]}>
            <Target className="w-5 h-5 text-primary shrink-0 mt-0.5" />
            <div>
              <h3 class="text-sm font-semibold mb-1">{o.area}</h3>
              <p class="text-xs text-muted-foreground leading-relaxed">{o.skill}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
