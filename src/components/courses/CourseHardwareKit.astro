---
import { Cpu, CircuitBoard, Wrench, CheckCircle2 } from "lucide-react";

interface KitCategory {
  title: string;
  icon: any;
  items: string[];
}

interface Props {
  categories: KitCategory[];
}

const { categories } = Astro.props;
---

<section class="py-16 md:py-24 bg-muted/30">
  <div class="responsive-container">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-10 reveal">
        <h2 class="text-2xl md:text-3xl font-semibold tracking-tight mb-4">Recommended Hardware Kit</h2>
        <p class="text-muted-foreground max-w-2xl mx-auto">
          Students need access to the following hardware components. A pre-bundled starter kit covering all items is available through the course store.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {categories.map((cat, i) => (
          <div class:list={["p-6 rounded-2xl border border-border bg-card shadow-sm reveal", `reveal-delay-${i + 1}`]}>
            <h3 class="text-sm font-semibold mb-4 flex items-center gap-2">
              <cat.icon className="w-4 h-4 text-primary" />
              {cat.title}
            </h3>
            <ul class="space-y-2.5">
              {cat.items.map((item) => (
                <li class="flex items-center gap-2 text-xs text-muted-foreground">
                  <CheckCircle2 className="w-3 h-3 text-primary shrink-0" />
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
