---
import { Mail, MapPin, ArrowUpRight } from "lucide-react";

const footerLinks = {
  navigation: [
    { href: "/", label: "Home" },
    { href: "/about", label: "About" },
    { href: "/founder", label: "Founder" },
    { href: "/blog", label: "Blog" },
    { href: "/contact", label: "Contact" },
  ],
  learning: [
    { href: "/courses/python", label: "Python Mastery" },
    { href: "/courses/ai-fundamentals", label: "AI Fundamentals" },
    { href: "/courses/robotics-iot", label: "Robotics & IoT" },
  ],
};
---

<footer class="border-t border-border">
  <div class="responsive-container py-16 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-8">
      <div class="md:col-span-5 space-y-5">
        <a href="/" class="flex items-center gap-2.5">
          <div class="flex items-center justify-center w-8 h-8 rounded-lg bg-primary text-primary-foreground">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L2 7L12 12L22 7L12 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M2 17L12 22L22 17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M2 12L12 17L22 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span class="text-[15px] font-semibold tracking-tight">
            Robo<span class="text-primary">AI</span>
          </span>
        </a>
        <p class="text-sm text-muted-foreground leading-relaxed max-w-sm">
          Hands-on education in AI, robotics, and code for the next generation of builders and engineers.
        </p>
        <div class="flex items-center gap-4 text-sm text-muted-foreground">
          <a href="mailto:akandeidrisbello@gmail.com" class="flex items-center gap-1.5 hover:text-foreground transition-colors">
            <Mail className="w-4 h-4" />
            akandeidrisbello@gmail.com
          </a>
        </div>
      </div>

      <div class="md:col-span-2 space-y-4">
        <h4 class="text-xs font-semibold uppercase tracking-wider text-foreground">Navigation</h4>
        <ul class="space-y-2.5">
          {footerLinks.navigation.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-muted-foreground hover:text-foreground transition-colors duration-200 inline-flex items-center gap-0.5 group"
              >
                {link.label}
                <ArrowUpRight className="w-3 h-3 opacity-0 -translate-y-0.5 translate-x-0.5 group-hover:opacity-100 group-hover:translate-y-0 group-hover:translate-x-0 transition-all" />
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-2 space-y-4">
        <h4 class="text-xs font-semibold uppercase tracking-wider text-foreground">Programs</h4>
        <ul class="space-y-2.5">
          {footerLinks.learning.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-muted-foreground hover:text-foreground transition-colors duration-200 inline-flex items-center gap-0.5 group"
              >
                {link.label}
                <ArrowUpRight className="w-3 h-3 opacity-0 -translate-y-0.5 translate-x-0.5 group-hover:opacity-100 group-hover:translate-y-0 group-hover:translate-x-0 transition-all" />
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-3 space-y-4">
        <h4 class="text-xs font-semibold uppercase tracking-wider text-foreground">Stay updated</h4>
        <p class="text-sm text-muted-foreground">Get course launches and robotics tips.</p>
        <form class="flex gap-2" onsubmit="event.preventDefault();">
          <input
            type="email"
            placeholder="you@example.com"
            class="flex-1 h-10 px-4 text-sm rounded-full border border-input bg-transparent placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
          />
          <button
            type="submit"
            class="h-10 px-5 text-sm font-medium rounded-full bg-primary text-primary-foreground hover:bg-primary/90 transition-colors"
          >
            Join
          </button>
        </form>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-muted-foreground">
        &copy; {new Date().getFullYear()} RoboAI. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <a href="/privacy" class="text-xs text-muted-foreground hover:text-foreground transition-colors">
          Privacy Policy
        </a>
        <a href="/terms" class="text-xs text-muted-foreground hover:text-foreground transition-colors">
          Terms of Service
        </a>
      </div>
    </div>
  </div>
</footer>
