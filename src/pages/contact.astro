---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar/Navbar.astro";
import Footer from "@/components/Footer/Footer.astro";
import PageHeader from "@/components/PageHeader.astro";
import { Input } from "@/components/ui/input";
import { Textarea } from "@/components/ui/textarea";
import { Label } from "@/components/ui/label";
import { Mail, Send, Clock, MessageCircle } from "lucide-react";
---

<BaseLayout title="Contact" description="Get in touch with RoboAI. Ready to start your AI and robotics journey?">
  <Navbar slot="navbar" />

  <PageHeader
    eyebrow="Contact"
    title="Let's connect"
    description="Have questions about our courses or ready to enroll? We'd love to hear from you."
  />

  <section class="py-16 md:py-24">
    <div class="responsive-container">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="lg:col-span-2 reveal">
          <div class="p-6 md:p-8 rounded-2xl border border-border bg-card shadow-sm">
            <h2 class="text-lg font-semibold mb-6">Send us a message</h2>
            <form id="contact-form" class="space-y-5">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div class="space-y-2">
                  <Label for="name">Full Name</Label>
                  <Input type="text" id="name" name="name" required placeholder="John Doe" />
                </div>
                <div class="space-y-2">
                  <Label for="email">Email Address</Label>
                  <Input type="email" id="email" name="email" required placeholder="john@example.com" />
                </div>
              </div>

              <div class="space-y-2">
                <Label for="subject">Subject</Label>
                <Input type="text" id="subject" name="subject" required placeholder="Course inquiry" />
              </div>

              <div class="space-y-2">
                <Label for="message">Message</Label>
                <Textarea id="message" name="message" required rows={5} placeholder="Tell us about your goals and interests..." />
              </div>

              <button
                type="submit"
                class="inline-flex items-center justify-center gap-2 h-11 px-7 rounded-full text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 transition-all duration-200 shadow-sm hover:shadow-md hover:shadow-primary/10"
              >
                <Send className="w-4 h-4" />
                Send Message
              </button>
            </form>

            <div id="form-success" class="hidden mt-5 p-4 rounded-xl bg-green-500/10 border border-green-500/20 text-green-600 dark:text-green-400 text-sm">
              Thank you! Your message has been sent. We'll get back to you within 24 hours.
            </div>
          </div>
        </div>

        <div class="lg:col-span-1 space-y-5 reveal reveal-delay-1">
          <div class="p-6 rounded-2xl border border-border bg-card shadow-sm space-y-5">
            <h3 class="text-sm font-semibold">Get in touch</h3>
            <ul class="space-y-4">
              <li>
                <a href="mailto:akandeidrisbello@gmail.com" class="flex items-start gap-3 group">
                  <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary shrink-0 group-hover:bg-primary/15 transition-colors">
                    <Mail className="w-4 h-4" />
                  </div>
                  <div>
                    <p class="text-xs font-medium text-muted-foreground mb-0.5">Email</p>
                    <p class="text-sm font-medium group-hover:text-primary transition-colors">akandeidrisbello@gmail.com</p>
                  </div>
                </a>
              </li>
              <li>
                <div class="flex items-start gap-3">
                  <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary shrink-0">
                    <Clock className="w-4 h-4" />
                  </div>
                  <div>
                    <p class="text-xs font-medium text-muted-foreground mb-0.5">Response time</p>
                    <p class="text-sm font-medium">Within 24 hours</p>
                  </div>
                </div>
              </li>
              <li>
                <div class="flex items-start gap-3">
                  <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary shrink-0">
                    <MessageCircle className="w-4 h-4" />
                  </div>
                  <div>
                    <p class="text-xs font-medium text-muted-foreground mb-0.5">For admissions</p>
                    <p class="text-sm font-medium">admissions@roboai.com</p>
                  </div>
                </div>
              </li>
            </ul>
          </div>

          <div class="p-6 rounded-2xl bg-primary/5 border border-primary/15">
            <h3 class="text-sm font-semibold mb-1.5">Ready to start?</h3>
            <p class="text-xs text-muted-foreground mb-4 leading-relaxed">
              Browse our courses and find the perfect program for your goals.
            </p>
            <a
              href="/courses"
              class="inline-flex items-center justify-center gap-2 h-9 px-5 rounded-full text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 transition-colors"
            >
              View Courses
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const successMsg = document.getElementById("form-success");

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    form.classList.add("hidden");
    successMsg?.classList.remove("hidden");
  });
</script>
