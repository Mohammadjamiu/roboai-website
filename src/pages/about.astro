---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar/Navbar.astro";
import Footer from "@/components/Footer/Footer.astro";
import PageHeader from "@/components/PageHeader.astro";
import CTASection from "@/components/Home/CTASection.astro";
import { Lightbulb, Users, Rocket, Heart, ArrowRight, Mail, Bot, Cpu, BrainCircuit, Shield } from "lucide-react";

const values = [
  {
    icon: Lightbulb,
    title: "Innovation First",
    description: "Curriculum stays current with the latest advances in AI, robotics, and software engineering.",
  },
  {
    icon: Users,
    title: "Community Driven",
    description: "Peer collaboration, mentorship, and a supportive network of builders and learners.",
  },
  {
    icon: Rocket,
    title: "Practical Learning",
    description: "Every concept is reinforced through hands-on labs and real-world projects.",
  },
  {
    icon: Heart,
    title: "Accessible Education",
    description: "Quality technical education designed to be inclusive, affordable, and globally available.",
  },
];

const stats = [
  { value: "500+", label: "Students trained" },
  { value: "50+", label: "Projects built" },
  { value: "95%", label: "Completion rate" },
  { value: "3", label: "Core programs" },
];
---

<BaseLayout title="About" description="Learn about RoboAI's mission to democratize AI and robotics education.">
  <Navbar slot="navbar" />

  <PageHeader
    eyebrow="About RoboAI"
    title="Shaping the future of tech education"
    description="We believe understanding AI and robotics is about empowering the next generation to build a better world."
  />

  <section class="py-16 md:py-24">
    <div class="responsive-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="reveal">
          <h2 class="text-2xl md:text-3xl font-semibold tracking-tight mb-5">
            From a vision to a learning platform
          </h2>
          <div class="space-y-4 text-muted-foreground leading-relaxed">
            <p>
              RoboAI was founded to bridge the gap between academic learning and industry demands in artificial intelligence, robotics, and software development.
            </p>
            <p>
              Built by educators and engineers who experienced the challenges of learning complex technical skills firsthand, RoboAI combines theoretical depth with practical, hands-on experience.
            </p>
            <p>
              From a small team to a growing community of learners, our focus remains the same: quality instruction, innovative curriculum, and an unwavering commitment to student success.
            </p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4 reveal">
          {stats.map((stat) => (
            <div class="p-6 rounded-2xl border border-border bg-card">
              <p class="text-3xl font-semibold tracking-tight text-primary mb-1">{stat.value}</p>
              <p class="text-sm text-muted-foreground">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="responsive-container">
      <div class="text-center max-w-xl mx-auto mb-12 reveal">
        <p class="text-xs font-semibold uppercase tracking-wider text-primary mb-3">Our Team</p>
        <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">
          Meet the engineers behind RoboAI
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <div class="p-6 rounded-2xl border border-border bg-card shadow-sm reveal">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-16 h-16 rounded-xl bg-primary/10 border border-primary/20 overflow-hidden flex-shrink-0">
              <img src="/authors-image.png" alt="Engr. Idris Bello Akande GMNSE" class="w-full h-full object-cover" />
            </div>
            <div>
              <h3 class="text-lg font-semibold">Engr. Idris Bello Akande GMNSE</h3>
              <p class="text-sm text-primary">Founder & Lead Instructor</p>
            </div>
          </div>
          <p class="text-sm text-muted-foreground leading-relaxed mb-4">
            Mechatronics Engineer with a First-Class degree (CGPA 4.75/5.00) from Bayero University, Kano. Founder of RoboAI, dedicated to empowering the next generation of engineers through AI, robotics, and programming education.
          </p>
          <div class="mb-4">
            <p class="text-xs font-medium mb-2">Education</p>
            <p class="text-sm text-muted-foreground">B.Eng Mechatronics Engineering, First Class (CGPA 4.75/5.00), BUK</p>
          </div>
          <div class="mb-4">
            <p class="text-xs font-medium mb-2">Research Interests</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="text-xs px-2.5 py-1 rounded-full bg-muted border border-border">Rehabilitation Robotics</span>
              <span class="text-xs px-2.5 py-1 rounded-full bg-muted border border-border">Neuroengineering</span>
              <span class="text-xs px-2.5 py-1 rounded-full bg-muted border border-border">Machine Learning</span>
              <span class="text-xs px-2.5 py-1 rounded-full bg-muted border border-border">Human-Robot Interaction</span>
            </div>
          </div>
          <a href="/founder" class="inline-flex items-center gap-1.5 text-sm text-primary hover:text-primary/80 transition-colors">
            <ArrowRight className="w-3.5 h-3.5" />
            View Profile
          </a>
        </div>

        <div class="p-6 rounded-2xl border border-border bg-card shadow-sm reveal">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-16 h-16 rounded-xl bg-primary/10 border border-primary/20 overflow-hidden flex-shrink-0">
              <img src="/yazeed-image.png" alt="Engr Yezeed Mohammed GMNSE" class="w-full h-full object-cover" />
            </div>
            <div>
              <h3 class="text-lg font-semibold">Engr Yezeed Mohammed GMNSE</h3>
              <p class="text-sm text-primary">Mechatronics Engineer</p>
            </div>
          </div>
          <p class="text-sm text-muted-foreground leading-relaxed mb-4">
            Motivated and innovative Mechatronics Engineer with hands-on experience in robotics, embedded systems, 3D printing and CNC machining. Skilled in 3D design, programming, and automation.
          </p>
          <div class="mb-4">
            <p class="text-xs font-medium mb-2">Education</p>
            <p class="text-sm text-muted-foreground">B.Eng Mechatronics Engineering, Air Force Institute of Technology</p>
          </div>
          <div class="mb-4">
            <p class="text-xs font-medium mb-2">Research Interests</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="text-xs px-2.5 py-1 rounded-full bg-muted border border-border">Robotics & Automation</span>
              <span class="text-xs px-2.5 py-1 rounded-full bg-muted border border-border">Embedded Systems</span>
              <span class="text-xs px-2.5 py-1 rounded-full bg-muted border border-border">Drone Technology</span>
              <span class="text-xs px-2.5 py-1 rounded-full bg-muted border border-border">Humanoid Robots</span>
            </div>
          </div>
          <a href="mailto:yezeedmuhammedking@gmail.com" class="inline-flex items-center gap-1.5 text-sm text-primary hover:text-primary/80 transition-colors">
            <Mail className="w-3.5 h-3.5" />
            Contact
          </a>
        </div>

        <div class="p-6 rounded-2xl border border-border bg-card shadow-sm reveal">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-16 h-16 rounded-xl bg-primary/10 border border-primary/20 overflow-hidden flex-shrink-0">
              <img src="/mohammad-jamiu.jpg" alt="Mohammad-Jamiu B. Balogun GMNSE" class="w-full h-full object-cover" />
            </div>
            <div>
              <h3 class="text-lg font-semibold">Mohammad-Jamiu B. Balogun GMNSE</h3>
              <p class="text-sm text-primary">AI Security Researcher</p>
            </div>
          </div>
          <p class="text-sm text-muted-foreground leading-relaxed mb-4">
            AI security researcher and telecommunications engineer with a First-Class degree (CGPA 4.64/5.00) from Bayero University, Kano. Founder of MonoEd Africa, serving over 10,000 students across Nigeria.
          </p>
          <div class="mb-4">
            <p class="text-xs font-medium mb-2">Education</p>
            <p class="text-sm text-muted-foreground">B.Eng Telecommunications Engineering, First Class (CGPA 4.64/5.00), Best Graduating Student, BUK</p>
          </div>
          <div class="mb-4">
            <p class="text-xs font-medium mb-2">Research Interests</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="text-xs px-2.5 py-1 rounded-full bg-muted border border-border">AI & LLM Security</span>
              <span class="text-xs px-2.5 py-1 rounded-full bg-muted border border-border">Secure Code Generation</span>
              <span class="text-xs px-2.5 py-1 rounded-full bg-muted border border-border">Network Security</span>
              <span class="text-xs px-2.5 py-1 rounded-full bg-muted border border-border">Cybersecurity</span>
            </div>
          </div>
          <a href="mailto:mohammad-jamiu@example.com" class="inline-flex items-center gap-1.5 text-sm text-primary hover:text-primary/80 transition-colors">
            <Mail className="w-3.5 h-3.5" />
            Contact
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-muted/30">
    <div class="responsive-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="order-2 lg:order-1 reveal">
          <div class="aspect-square max-w-sm mx-auto rounded-2xl border border-border bg-card flex items-center justify-center p-8 overflow-hidden">
            <img src="/authors-image.png" alt="Engr. Idris Bello Akande GMNSE" class="w-full h-full object-cover rounded-xl" />
          </div>
        </div>
        <div class="order-1 lg:order-2 reveal">
          <p class="text-xs font-semibold uppercase tracking-wider text-primary mb-3">Meet the Founder</p>
          <h2 class="text-2xl md:text-3xl font-semibold tracking-tight mb-5">
            Engineer, researcher, educator
          </h2>
          <div class="space-y-4 text-muted-foreground leading-relaxed mb-6">
            <p>
              Idris is a Mechatronics Engineer with a First-Class degree from Bayero University, Kano. His research spans rehabilitation robotics, neuroengineering, machine learning, and human-robot interaction.
            </p>
            <p>
              He founded RoboAI to make advanced technical education practical, accessible, and grounded in real engineering experience.
            </p>
          </div>
          <a
            href="/founder"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:text-primary/80 transition-colors group"
          >
            Read full profile
            <ArrowRight className="w-4 h-4 group-hover:translate-x-0.5 transition-transform" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="responsive-container">
      <div class="text-center max-w-xl mx-auto mb-12 reveal">
        <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">
          What drives us forward
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 max-w-3xl mx-auto">
        {values.map((value, i) => (
          <div class:list={["p-6 rounded-2xl border border-border bg-card shadow-sm reveal", `reveal-delay-${i + 1}`]}>
            <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-primary/10 text-primary mb-4">
              <value.icon className="w-5 h-5" />
            </div>
            <h3 class="text-base font-semibold mb-2">{value.title}</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
  <Footer slot="footer" />
</BaseLayout>
