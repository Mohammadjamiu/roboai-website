---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar/Navbar.astro";
import Footer from "@/components/Footer/Footer.astro";
import PageHeader from "@/components/PageHeader.astro";
import {
  GraduationCap,
  Award,
  BookOpen,
  Users,
  BrainCircuit,
  Bot,
  Cpu,
  Mail,
  Phone,
  Linkedin,
  Github,
  BadgeCheck,
} from "lucide-react";

const researchInterests = [
  "Rehabilitation Robotics",
  "Neuroengineering",
  "Artificial Intelligence",
  "Machine Learning",
  "Intelligent Control Systems",
  "Human-Robot Interaction",
  "Assistive Healthcare Technologies",
];

const awards = [
  {
    title: "Winner, Inter-Platoon Debate Competition",
    org: "National Youth Service Corps",
    description: 'Topic: "Is Artificial Intelligence Beneficial or Harmful to Society?"',
  },
  {
    title: "University Scholarship Recipient",
    org: "Bayero University, Kano",
    description: "Awarded to the best student in class for every session",
  },
  {
    title: "Dean's List",
    org: "Bayero University, Kano",
    description: "Consistently featured in Dean's list for all semesters",
  },
  {
    title: "Student ACE Award",
    org: "Edu North Summit",
    description: "Celebrating exceptional students with good leadership and community service track records",
  },
  {
    title: "Courses Challenge Competition Award",
    org: "NUESA",
    description: "Nigerian Universities Engineering Students' Association",
  },
];

const certifications = [
  { provider: "Udemy", course: "Machine Learning, Data Science & AI Engineering with Python" },
  { provider: "Great Learning", course: "Robotics and AI" },
  { provider: "MathWorks", course: "MATLAB, Machine Learning and Deep Learning Onramp" },
  { provider: "NIPES", course: "Artificial Intelligence and Python Programming" },
];

const memberships = [
  { name: "International Association of Engineers (IAEng)", id: "Membership No: 5255113" },
  { name: "National Institute of Professional Engineers & Scientists (NIPES)", id: "Certificate No: A01-000599" },
];
---

<BaseLayout title="Engr. Idris Bello Akande GMNSE | Founder of RoboAI" description="Idris Bello Akande GMNSE is a Mechatronics Engineer and founder of RoboAI, dedicated to empowering the next generation of engineers through AI, robotics, and programming education.">
  <Navbar slot="navbar" />

  <PageHeader
    eyebrow="Founder"
    title="Engr. Idris Bello Akande GMNSE"
    description="Mechatronics Engineer, researcher, and founder of RoboAI."
  />

  <section class="py-12 md:py-16">
    <div class="responsive-container">
      <div class="max-w-4xl mx-auto">
        <div class="flex flex-col md:flex-row items-start gap-8 mb-12 reveal">
          <div class="flex-shrink-0">
            <div class="w-28 h-28 md:w-36 md:h-36 rounded-2xl bg-primary/10 border border-primary/20 overflow-hidden">
              <img src="/authors-image.png" alt="Engr. Idris Bello Akande GMNSE" class="w-full h-full object-cover" />
            </div>
          </div>

          <div class="flex-1 space-y-4">
            <div>
              <div class="flex items-center gap-2 mb-1">
                <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">Engr. Idris Bello Akande GMNSE</h2>
                <BadgeCheck className="w-5 h-5 text-primary" />
              </div>
              <p class="text-sm text-muted-foreground">Mechatronics Engineer - Founder, RoboAI</p>
            </div>

            <div class="space-y-3 text-sm text-muted-foreground leading-relaxed">
              <p>
                Mechatronics Engineer with a First-Class degree (CGPA 4.75/5.00) from Bayero University, Kano. His research interests span rehabilitation robotics, neuroengineering, machine learning, reinforcement learning, intelligent control systems, and human-robot interaction.
              </p>
              <p>
                He is the founder of RoboAI, an educational initiative dedicated to empowering the next generation of engineers through world-class training in artificial intelligence, robotics, and programming.
              </p>
            </div>

            <div class="flex flex-wrap gap-3 pt-2">
              <a
                href="tel:+2347061142372"
                class="inline-flex items-center gap-1.5 h-9 px-4 rounded-full text-sm font-medium border border-input hover:bg-muted transition-colors"
              >
                <Phone className="w-4 h-4" />
                +2347061142372
              </a>
              <a
                href="mailto:akandeidrisbello@gmail.com"
                class="inline-flex items-center gap-1.5 h-9 px-4 rounded-full text-sm font-medium border border-input hover:bg-muted transition-colors"
              >
                <Mail className="w-4 h-4" />
                Email
              </a>
              <a
                href="https://www.linkedin.com/in/idris-akande-bello-0824b5382"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 h-9 px-4 rounded-full text-sm font-medium border border-input hover:bg-muted transition-colors"
              >
                <Linkedin className="w-4 h-4" />
                LinkedIn
              </a>
              <a
                href="https://github.com/idrisabello"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 h-9 px-4 rounded-full text-sm font-medium border border-input hover:bg-muted transition-colors"
              >
                <Github className="w-4 h-4" />
                GitHub
              </a>
              <a
                href="/courses"
                class="inline-flex items-center gap-1.5 h-9 px-4 rounded-full text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 transition-colors"
              >
                <BookOpen className="w-4 h-4" />
                View Courses
              </a>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          <div class="lg:col-span-2 space-y-10">
            <div class="reveal">
              <div class="flex items-center gap-2 mb-4">
                <GraduationCap className="w-5 h-5 text-primary" />
                <h3 class="text-lg font-semibold">Education</h3>
              </div>
              <div class="p-5 rounded-2xl border border-border bg-card">
                <div class="flex items-start justify-between gap-4 mb-3">
                  <div>
                    <p class="font-medium">Bachelor of Engineering, Mechatronics Engineering</p>
                    <p class="text-sm text-muted-foreground mt-0.5">Bayero University, Kano (BUK) - Nigeria</p>
                  </div>
                  <span class="flex-shrink-0 text-xs font-semibold px-2.5 py-1 rounded-full bg-primary/10 text-primary">
                    CGPA 4.75/5.00
                  </span>
                </div>
                <p class="text-sm text-muted-foreground">
                  <span class="font-medium text-foreground">Thesis:</span> Design and Construction of IoT-based Health Monitoring System with Pill Dispensing Capabilities
                </p>
                <span class="inline-block mt-3 text-[10px] font-semibold px-2.5 py-1 rounded-full bg-green-500/10 text-green-600 dark:text-green-400 border border-green-500/20">
                  First Class
                </span>
              </div>
            </div>

            <div class="reveal">
              <div class="flex items-center gap-2 mb-4">
                <BrainCircuit className="w-5 h-5 text-primary" />
                <h3 class="text-lg font-semibold">Research Interests</h3>
              </div>
              <div class="flex flex-wrap gap-2">
                {researchInterests.map((interest) => (
                  <span class="text-xs px-3 py-1.5 rounded-full bg-muted border border-border text-foreground">
                    {interest}
                  </span>
                ))}
              </div>
            </div>

            <div class="reveal">
              <div class="flex items-center gap-2 mb-4">
                <Award className="w-5 h-5 text-primary" />
                <h3 class="text-lg font-semibold">Honours & Awards</h3>
              </div>
              <div class="space-y-3">
                {awards.map((award) => (
                  <div class="p-4 rounded-xl border border-border bg-card hover:border-primary/20 transition-colors">
                    <p class="text-sm font-medium">{award.title}</p>
                    <p class="text-xs text-primary mt-0.5">{award.org}</p>
                    <p class="text-xs text-muted-foreground mt-1">{award.description}</p>
                  </div>
                ))}
              </div>
            </div>

            <div class="reveal">
              <div class="flex items-center gap-2 mb-4">
                <BookOpen className="w-5 h-5 text-primary" />
                <h3 class="text-lg font-semibold">Courses & Certifications</h3>
              </div>
              <div class="space-y-3">
                {certifications.map((cert) => (
                  <div class="flex items-start gap-3 p-4 rounded-xl border border-border bg-card">
                    <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center text-primary shrink-0">
                      <BookOpen className="w-4 h-4" />
                    </div>
                    <div>
                      <p class="text-xs text-muted-foreground">{cert.provider}</p>
                      <p class="text-sm font-medium">{cert.course}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <div class="lg:col-span-1 space-y-6">
            <div class="p-5 rounded-2xl border border-border bg-card reveal">
              <h3 class="text-sm font-semibold mb-4">Quick Facts</h3>
              <ul class="space-y-4">
                <li class="flex items-center gap-3">
                  <GraduationCap className="w-4 h-4 text-primary shrink-0" />
                  <div>
                    <p class="text-xs font-medium">Education</p>
                    <p class="text-xs text-muted-foreground">B.Eng Mechatronics, First Class</p>
                  </div>
                </li>
                <li class="flex items-center gap-3">
                  <Cpu className="w-4 h-4 text-primary shrink-0" />
                  <div>
                    <p class="text-xs font-medium">Field</p>
                    <p class="text-xs text-muted-foreground">Mechatronics Engineering</p>
                  </div>
                </li>
                <li class="flex items-center gap-3">
                  <Bot className="w-4 h-4 text-primary shrink-0" />
                  <div>
                    <p class="text-xs font-medium">Focus</p>
                    <p class="text-xs text-muted-foreground">Rehabilitation Robotics & AI</p>
                  </div>
                </li>
                <li class="flex items-center gap-3">
                  <Users className="w-4 h-4 text-primary shrink-0" />
                  <div>
                    <p class="text-xs font-medium">Role</p>
                    <p class="text-xs text-muted-foreground">Founder, RoboAI</p>
                  </div>
                </li>
              </ul>
            </div>

            <div class="p-5 rounded-2xl border border-border bg-card reveal">
              <h3 class="text-sm font-semibold mb-4">Professional Memberships</h3>
              <ul class="space-y-3">
                {memberships.map((m) => (
                  <li>
                    <p class="text-xs font-medium">{m.name}</p>
                    <p class="text-[10px] text-muted-foreground">{m.id}</p>
                  </li>
                ))}
              </ul>
            </div>

            <div class="p-5 rounded-2xl bg-primary/5 border border-primary/15 reveal">
              <h3 class="text-sm font-semibold mb-1.5">Connect with Idris</h3>
              <p class="text-xs text-muted-foreground mb-4 leading-relaxed">
                Interested in collaboration, research, or speaking engagements?
              </p>
              <div class="space-y-2">
                <a
                  href="tel:+2347061142372"
                  class="inline-flex items-center justify-center gap-1.5 h-9 px-4 rounded-full text-sm font-medium border border-input hover:bg-muted transition-colors w-full"
                >
                  <Phone className="w-4 h-4" />
                  +2347061142372
                </a>
                <a
                  href="mailto:akandeidrisbello@gmail.com"
                  class="inline-flex items-center justify-center gap-1.5 h-9 px-4 rounded-full text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 transition-all duration-200 w-full"
                >
                  <Mail className="w-4 h-4" />
                  Send Email
                </a>
                <a
                  href="https://www.linkedin.com/in/idris-akande-bello-0824b5382"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center gap-1.5 h-9 px-4 rounded-full text-sm font-medium border border-input hover:bg-muted transition-colors w-full"
                >
                  <Linkedin className="w-4 h-4" />
                  LinkedIn
                </a>
                <a
                  href="https://github.com/idrisabello"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center gap-1.5 h-9 px-4 rounded-full text-sm font-medium border border-input hover:bg-muted transition-colors w-full"
                >
                  <Github className="w-4 h-4" />
                  GitHub
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
