---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar/Navbar.astro";
import Footer from "@/components/Footer/Footer.astro";
import PageHeader from "@/components/PageHeader.astro";
import CTASection from "@/components/Home/CTASection.astro";
import { ArrowRight, Calendar, Clock, User } from "lucide-react";

const posts = [
  {
    title: "Torque Control of an Elbow Joint Using a Markov Decision Process and Deep Q-Network",
    description: "A simulation-based torque control approach for an elbow joint using reinforcement learning, demonstrating stable learning behavior and effective trajectory tracking for rehabilitation robotics.",
    slug: "torque-control-elbow-joint-dqn",
    author: "Engr. Idris Bello Akande GMNSE",
    date: "June 2026",
    readTime: "15 min read",
    tags: ["Reinforcement Learning", "Robotics", "DQN", "Rehabilitation"],
    image: "/figure2_tracking_angle.png",
  },
];
---

<BaseLayout title="Blog" description="Technical articles and research insights from the RoboAI team on AI, robotics, and engineering.">
  <Navbar slot="navbar" />

  <PageHeader
    eyebrow="Blog"
    title="Technical insights & research"
    description="Deep dives into AI, robotics, and engineering from our team of researchers and engineers."
  />

  <section class="py-16 md:py-24">
    <div class="responsive-container">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
        {posts.map((post, i) => (
          <a
            href={`/blog/${post.slug}`}
            class:list={["group relative flex flex-col rounded-2xl border border-border bg-card shadow-sm overflow-hidden hover-lift reveal", `reveal-delay-${(i % 3) + 1}`]}
          >
            <div class="aspect-video overflow-hidden">
              <img
                src={post.image}
                alt={post.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
            <div class="flex flex-col flex-1 p-5">
              <div class="flex flex-wrap gap-1.5 mb-3">
                {post.tags.map((tag) => (
                  <span class="text-[10px] px-2 py-0.5 rounded-full bg-primary/10 text-primary font-medium">{tag}</span>
                ))}
              </div>
              <h3 class="text-base font-semibold mb-2 group-hover:text-primary transition-colors line-clamp-2">{post.title}</h3>
              <p class="text-sm text-muted-foreground leading-relaxed mb-4 flex-1 line-clamp-3">{post.description}</p>
              <div class="flex items-center justify-between text-xs text-muted-foreground pt-3 border-t border-border">
                <div class="flex items-center gap-3">
                  <span class="flex items-center gap-1">
                    <Calendar className="w-3 h-3" />
                    {post.date}
                  </span>
                  <span class="flex items-center gap-1">
                    <Clock className="w-3 h-3" />
                    {post.readTime}
                  </span>
                </div>
                <ArrowRight className="w-4 h-4 group-hover:translate-x-0.5 transition-transform text-primary" />
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
  <Footer slot="footer" />
</BaseLayout>
